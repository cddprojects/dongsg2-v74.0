DirectoryIndex index.html

<IfModule mod_rewrite.c>
RewriteEngine On

# Serve subpages internally only (no external redirects — avoids nginx/Plesk loops)
RewriteRule ^privacy-policy/?$ privacy-policy/index.html [L]
RewriteRule ^thank-you/?$ thank-you/index.html [L]

# Redirect root index.html only
RewriteRule ^index\.html$ / [R=301,L]
</IfModule>
